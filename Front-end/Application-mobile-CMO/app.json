{
  "expo": {
    "name": "CMO",
    "slug": "CMO",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cmo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.abdellah112233.CMO"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "updates": {
  "url": "https://u.expo.dev/33c0754e-86e4-40b9-ba7c-060d4ab91442"
},
"runtimeVersion": {
  "policy": "appVersion"
},
    "extra": {
      "router": {},
      "eas": {
        "projectId": "33c0754e-86e4-40b9-ba7c-060d4ab91442"
      }
    }
  }
}
